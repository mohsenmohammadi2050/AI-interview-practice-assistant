# LLM provider config
LLM_PROVIDER=openrouter
LLM_API_KEY=your_openrouter_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=nex-agi/nex-n2-pro:free
LLM_MAX_RETRIES=3

# Optional HTTP headers for OpenRouter
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=AI Interview Coach

# Transcription provider config
TRANSCRIPTION_PROVIDER=groq
TRANSCRIPTION_API_KEY=your_groq_api_key_here
# Alternative: leave TRANSCRIPTION_API_KEY empty and set GROQ_API_KEY instead.
# GROQ_API_KEY=your_groq_api_key_here
TRANSCRIPTION_BASE_URL=https://api.groq.com/openai/v1
TRANSCRIPTION_MODEL=whisper-large-v3

# Backend config
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATA_DIR=./data
AGENT_DEBUG_LOGS=true
